# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────
# Used by Streamlit Community Cloud's built-in secrets manager.
# Paste these values in:
#   share.streamlit.io → App settings → Secrets
#
# DO NOT commit this file — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────

OPENAI_API_KEY   = "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional — only needed if running eval_crew.py from the dashboard
# ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# GOOGLE_API_KEY    = "AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
